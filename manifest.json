{
  "manifest_version": 3,
  "name": "GitHub Commit Enter Key",
  "version": "1.0",
  "description": "Press Enter to commit changes on GitHub",
  "permissions": [],
  "host_permissions": ["https://github.com/*"],
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content.js"]
    }
  ]
}